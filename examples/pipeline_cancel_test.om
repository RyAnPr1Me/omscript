// Test: pipeline failure semantics
//
// Requirements:
//   • Stages execute in sequence.
//   • If a non-final stage fails (throw), the pipeline cancels: remaining
//     middle stages are skipped.
//   • The last stage ALWAYS runs — even after a failure.
//   • After a failure the counted pipeline exits immediately (no more iterations).

fn main() {
    var total = 0;

    // ── 1. Normal pipeline — no failure ─────────────────────────────────────
    // Three stages, 3 iterations.  All stages run every time.
    // load: x = __pipeline_i
    // double: y = x * 2
    // accum: sum += y   → 0+2+4 = 6
    var sum1 = 0;
    var x1 = 0;
    var y1 = 0;
    pipeline 3 {
        stage load   { x1 = __pipeline_i; }
        stage double { y1 = x1 * 2; }
        stage accum  { sum1 = sum1 + y1; }
    }
    total = total + sum1;   // 6

    // ── 2. One-shot pipeline with failure → last stage still runs ───────────
    // Stage init sets a=10, stage fail throws, stage cleanup sets b=1.
    // The throw in stage fail should skip nothing (it's the middle stage)
    // and cleanup (last stage) should still run.
    var a2 = 0;
    var b2 = 0;
    try {
        pipeline {
            stage init    { a2 = 10; }
            stage fail    { throw 42; }
            stage cleanup { b2 = 1; }
        }
    } catch (e) {
        // The error is caught here (or handled internally).
    }
    // a2 should be 10 (init ran), b2 should be 1 (cleanup ran despite throw).
    total = total + a2;     // +10 → 16
    total = total + b2;     // +1  → 17

    // ── 3. Counted pipeline with failure on first iteration ─────────────────
    // 5 iterations, but stage work throws on iteration 0.
    // last-stage (accum) should still run on iteration 0, then loop exits.
    var sum3 = 0;
    var iters3 = 0;
    try {
        pipeline 5 {
            stage work  { throw 99; }
            stage accum { sum3 = sum3 + 1; iters3 = iters3 + 1; }
        }
    } catch (e) {
        // swallow
    }
    // accum (last stage) ran once (iteration 0), then pipeline cancelled.
    total = total + sum3;    // +1 → 18
    total = total + iters3;  // +1 → 19

    // ── 4. Three stages, middle stage fails on iteration 2 ──────────────────
    // 5 iterations.  Stage check throws when __pipeline_i == 2.
    // Stage cleanup always runs.  Stage process should only run for i<2.
    var processed = 0;
    var cleaned = 0;
    try {
        pipeline 5 {
            stage check {
                if (__pipeline_i == 2) {
                    throw 1;
                }
            }
            stage process { processed = processed + 1; }
            stage cleanup { cleaned = cleaned + 1; }
        }
    } catch (e) {
        // swallow
    }
    // Iterations 0,1 fully succeed → processed=2, cleaned=2
    // Iteration 2: check throws → process skipped → cleanup runs → cleaned=3
    // Pipeline cancels after iteration 2.
    total = total + processed;  // +2 → 21
    total = total + cleaned;    // +3 → 24

    // ── 5. Single-stage pipeline — no finally semantics needed ──────────────
    var sum5 = 0;
    pipeline 4 {
        stage only { sum5 = sum5 + __pipeline_i; }
    }
    total = total + sum5;   // 0+1+2+3 = 6 → 30

    // ── 6. One-shot pipeline, all stages succeed ────────────────────────────
    var v6 = 1;
    pipeline {
        stage a { v6 = v6 + 1; }
        stage b { v6 = v6 * 3; }
        stage c { v6 = v6 + 10; }
    }
    total = total + v6;   // (1+1)*3+10 = 16 → 46

    // Expected: 6 + 10 + 1 + 1 + 1 + 2 + 3 + 6 + 16 = 46
    return total;
}
