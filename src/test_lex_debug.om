import "lexer.om";

fn main() {
    var src = "fn add(a: i64, b: i64) -> i64 { return a + b; }";
    var ts = tokenize(src);
    var i = 0;
    while (i < ts.count) {
        println(to_string(i) + ": type=" + to_string(ts.types[i]) + " [" + ts.lexemes[i] + "]");
        i = i + 1;
    }
    return 0;
}
