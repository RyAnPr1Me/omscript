import std;
// Test: flag predicate scheduling pass
//
// Exercises the three phases of FlagPredicateSchedulingPass:
//
//  Phase 1 – round-trip elimination:
//    c = (x >= lo); result += c
//    The codegen emits `zext i1 (icmp sge) to i64`.  When `c` is later used
//    as a condition it would become `icmp ne i64 (zext i1), 0`; the pass
//    collapses that back to the original i1.
//
//  Phase 2 – same-operand comparison deduplication:
//    lt_or_eq  = (x < hi) || (x == hi) — both compare (x, hi);
//    The pass expresses `sle` as `or(slt, eq)` so the backend needs one CMP.
//
//  Phase 3 – PF parity packing:
//    xor of two icmp results → pack into byte + ctpop.
//    `(a > 0) XOR (b > 0)` is the parity of the packed byte, which maps to
//    POPCNT on x86 and frees one GPR.

// ── 1. Boolean accumulation (exercises round-trip elimination) ────────────────
@noinline
fn count_valid(a: int, b: int, c: int, d: int) {
    var count = 0;
    count = count + (a > 0);
    count = count + (b > 0);
    count = count + (c > 0);
    count = count + (d > 0);
    return count;   // returns the number of positive values
}

// ── 2. Range check with repeated operands (exercises Phase 2) ─────────────────
@noinline
fn in_range_strict(x: int, lo: int, hi: int) {
    var above_lo = x >= lo;   // sge
    var below_hi = x <= hi;   // sle  — same-op group with icmp slt + icmp eq
    return above_lo && below_hi;
}

// ── 3. XOR of two icmp results (exercises Phase 3 PF packing) ─────────────────
@noinline
fn diff_sign(a: int, b: int) {
    var apos = a > 0;
    var bpos = b > 0;
    // Returns 1 iff exactly one of a, b is positive.
    // At IR level this is `xor i1 (icmp sgt a, 0), (icmp sgt b, 0)`.
    // FlagPredicateSchedulingPass packs the two i1s into one byte and uses
    // POPCNT to compute the XOR, exploiting PF.
    return apos != bpos;
}

// ── 4. Multi-condition branch (exercises all phases together) ─────────────────
@noinline
fn classify(x: int) {
    if (x > 0 && x < 100 && x != 50) {
        return 1;
    }
    if (x == 0) {
        return 0;
    }
    return -1;
}

fn main() {
    // count_valid(1, -1, 2, 0) → 2 positive values (1 and 2 are > 0) → 2
    var r1 = count_valid(1, -1, 2, 0);

    // in_range_strict(5, 0, 10) → true → 1
    var r2 = in_range_strict(5, 0, 10);

    // in_range_strict(15, 0, 10) → false → 0
    var r3 = in_range_strict(15, 0, 10);

    // diff_sign(3, -5) → true → 1   (one positive, one negative)
    var r4 = diff_sign(3, -5);

    // diff_sign(3, 5) → false → 0   (both positive)
    var r5 = diff_sign(3, 5);

    // classify(25) → 1 (in (0,100), ≠ 50)
    var r6 = classify(25);

    // classify(50) → -1 (== 50, excluded)
    var r7 = classify(50);

    // classify(0) → 0 (zero)
    var r8 = classify(0);

    // classify(-3) → -1 (negative)
    var r9 = classify(-3);

    // Expected total: 2 + 1 + 0 + 1 + 0 + 1 + (-1) + 0 + (-1) = 3
    return r1 + r2 + r3 + r4 + r5 + r6 + r7 + r8 + r9;
}
