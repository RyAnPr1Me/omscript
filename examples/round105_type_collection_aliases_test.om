import std;

// Round-105: additional generic collection aliases in type annotations.
// Verifies:
//   list<T>                -> T[]
//   vector<T>              -> T[]
//   hashmap<K,V>           -> dict[K,V]
// and nested combinations with existing aliases.

fn main() -> int {
    var score: int = 0;

    var xs: list<int> = [1, 2, 3];
    if xs[2] == 3 { score = score + 1; } // 1

    var grid: vector<vector<int>> = [[1, 2], [3, 4]];
    if grid[1][1] == 4 { score = score + 1; } // 2

    var lookup: hashmap<int, int> = {1: 7, 2: 9};
    if lookup[2] == 9 { score = score + 1; } // 3

    var grouped: hashmap<int, list<int>> = {5: [8, 13]};
    if grouped[5][0] == 8 { score = score + 1; } // 4

    var alias_mix: hashmap<int, vector<integer>> = {3: [21]};
    if alias_mix[3][0] == 21 { score = score + 1; } // 5

    return score;
}
