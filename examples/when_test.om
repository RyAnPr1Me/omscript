// Test: when statement
// when (expr) { val => { ... }, _ => { ... } } — pattern-matching switch

fn day_type(day) {
    var result = 0;
    when (day) {
        1, 2, 3, 4, 5 => { result = 1; }
        6, 7 => { result = 2; }
        _ => { result = 0; }
    }
    return result;
}

fn classify(x) {
    var result = 0;
    when (x) {
        0 => { result = 0; }
        1 => { result = 10; }
        2 => { result = 20; }
        3 => { result = 30; }
        _ => { result = -1; }
    }
    return result;
}

fn single_match(x) {
    var result = 0;
    when (x) {
        42 => { result = 100; }
        _ => { result = -100; }
    }
    return result;
}

fn main() {
    var total = 0;

    // day_type: weekdays = 1, weekends = 2, other = 0
    total = total + day_type(1);   // 1
    total = total + day_type(5);   // 1
    total = total + day_type(6);   // 2
    total = total + day_type(7);   // 2
    total = total + day_type(8);   // 0

    // classify
    total = total + classify(0);   // 0
    total = total + classify(1);   // 10
    total = total + classify(2);   // 20
    total = total + classify(3);   // 30
    total = total + classify(99);  // -1

    // single match
    total = total + single_match(42);   // 100
    total = total + single_match(0);    // -100

    // Expected: 1+1+2+2+0 + 0+10+20+30+(-1) + 100+(-100) = 65
    return total;
}
