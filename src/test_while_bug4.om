global var g_pos2 = 0;
global var g_arr = [89, 3, 83];

fn check2(ty) {
    if (g_pos2 >= len(g_arr)) { return 0; }
    return g_arr[g_pos2] == ty;
}

fn match2(ty) {
    if (check2(ty)) {
        g_pos2 = g_pos2 + 1;
        return 1;
    }
    return 0;
}

fn main() {
    g_pos2 = 0;
    println("direct: " + to_string(match2(89)));
    
    g_pos2 = 0;
    var cnt = 0;
    while (match2(89)) {
        cnt = cnt + 1;
        println("body! pos=" + to_string(g_pos2));
    }
    println("cnt=" + to_string(cnt));
    return 0;
}
