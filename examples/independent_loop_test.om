// Test @loop(independent=true) hint — marks the loop as having no
// cross-iteration memory dependencies, enabling aggressive vectorization.
fn main() {
    var a = [0, 0, 0, 0, 0, 0, 0, 0];
    var b = [1, 2, 3, 4, 5, 6, 7, 8];

    for (i in 0...8) @loop(independent=true) {
        a[i] = b[i] * 2;
    }

    // Sum to verify correctness: 2+4+6+8+10+12+14+16 = 72
    var sum = 0;
    for (i in 0...8) {
        sum = sum + a[i];
    }
    return sum;
}
