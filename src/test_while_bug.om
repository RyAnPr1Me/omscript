global var g_x = 0;

fn inc_and_check() {
    g_x = g_x + 1;
    if (g_x <= 3) { return 1; }
    return 0;
}

fn main() {
    // Direct call works
    println("direct: " + to_string(inc_and_check()));
    println("direct: " + to_string(inc_and_check()));
    
    g_x = 0;
    var cnt = 0;
    while (inc_and_check()) {
        cnt = cnt + 1;
        println("while body: cnt=" + to_string(cnt) + " g_x=" + to_string(g_x));
    }
    println("final cnt=" + to_string(cnt));
    
    return 0;
}
