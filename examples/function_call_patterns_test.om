// Function call conventions: default parameter values, multiple return
// paths, calls that pass values as both arguments and expressions.
fn add3(a:i64, b:i64, c:i64) {
    return a + b + c;
}

fn with_early_return(n:i64) {
    if (n < 0) { return -1; }
    if (n == 0) { return 0; }
    return n * 2;
}

fn sum_up_to(n:i64) {
    var s = 0;
    for (i in 0...n + 1) {
        s = s + i;
    }
    return s;
}

fn main() {
    var r = 0;

    // Simple call.
    if (add3(1, 2, 3) == 6) { r = r + 1; }

    // Nested calls (result of one passed to another).
    if (add3(add3(1, 1, 1), 2, 3) == 8) { r = r + 1; }

    // Early-return paths.
    if (with_early_return(-5) == -1) { r = r + 1; }
    if (with_early_return(0)  == 0)  { r = r + 1; }
    if (with_early_return(5)  == 10) { r = r + 1; }

    // Closed-form sum: 1+2+...+10 = 55.
    if (sum_up_to(10) == 55) { r = r + 1; }
    if (sum_up_to(0)  == 0)  { r = r + 1; }
    if (sum_up_to(1)  == 1)  { r = r + 1; }

    // Call inside a binary op.
    if (add3(1,1,1) + add3(2,2,2) == 9) { r = r + 1; }

    // Call inside a comparison.
    if (sum_up_to(4) < sum_up_to(5)) { r = r + 1; }

    return r;  // 10
}
