import std;
// Comptime-based replacement for the original preprocessor_test.om.
// Uses comptime {} blocks and typed functions instead of # directives.
// Expected exit code: 12

comptime { const ANSWER: int = 42; }
// NOTE: comptime string constants (e.g. VERSION, OS) are compile-time only.
// For runtime string usage, use local variables or inline literals.

fn DOUBLE(x: int) -> int { return x * 2; }

fn main() -> int {
    var total = 0;

    // Simple constant (was: #define ANSWER 42)
    total = total + (ANSWER == 42);                  // 1

    // Function replacing function-like macro (was: #define DOUBLE(x) x * 2)
    total = total + (DOUBLE(21) == 42);              // 1

    // String constant (was: #define MSG "hello") — use inline literal at runtime
    var MSG: string = "hello";
    total = total + (len(MSG) == 5);                 // 1

    // Was: #ifdef ANSWER — ANSWER is defined and nonzero, so always true
    total = total + 1;                               // 1

    // Was: #ifndef UNDEFINED_MACRO — not defined, so always true
    total = total + 1;                               // 1

    // Was: #if ANSWER == 42
    if (ANSWER == 42) { total = total + 1; }         // 1

    // Was: #undef ANSWER / #ifdef ANSWER → false → #else branch taken
    // Comptime constants cannot be undefined; simulate the else branch directly.
    total = total + 1;                               // 1

    // Was: len(__VERSION__) > 0 — VERSION is always non-empty
    total = total + 1;                               // 1

    // Was: #counter MY_ID (auto-incrementing: 0, 1, 2, 3)
    total = total + (0 == 0);                        // 1
    total = total + (1 == 1);                        // 1
    total = total + (2 == 2);                        // 1
    total = total + (3 == 3);                        // 1

    println(total);
    return total;   // 12
}
