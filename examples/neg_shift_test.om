fn main() {
    var a = (-1) << 3;
    assert(a == -8);

    var b = (-2) << 4;
    assert(b == -32);

    var c = (-1) << 0;
    assert(c == -1);

    var d = 1 << 10;
    assert(d == 1024);

    // Logical constant folding
    var e = 3 && 5;
    assert(e == 1);

    var f = 0 && 5;
    assert(f == 0);

    var g = 0 || 7;
    assert(g == 1);

    var h = 0 || 0;
    assert(h == 0);

    println(0);
    return 0;
}
