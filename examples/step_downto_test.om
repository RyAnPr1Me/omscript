// Test: step keyword and downto loop
// for (i in 0...10 step 2) — named step
// for (i in 10 downto 0) — reverse iteration

fn sum_even_indices(n) {
    var total = 0;
    for (i in 0...n step 2) {
        total = total + i;
    }
    return total;
}

fn sum_odd_indices(n) {
    var total = 0;
    for (i in 1...n step 2) {
        total = total + i;
    }
    return total;
}

fn count_down(start) {
    var total = 0;
    for (i in start downto 0) {
        total = total + i;
    }
    return total;
}

fn downto_with_step() {
    var total = 0;
    for (i in 10 downto 0 step 3) {
        total = total + i;
    }
    // 10, 7, 4, 1 => 10+7+4+1 = 22
    return total;
}

fn step_by_three() {
    var total = 0;
    for (i in 0...15 step 3) {
        total = total + i;
    }
    // 0, 3, 6, 9, 12 => 30
    return total;
}

fn main() {
    var total = 0;

    // sum even indices 0..10: 0+2+4+6+8 = 20
    total = total + sum_even_indices(10);

    // sum odd indices 1..10: 1+3+5+7+9 = 25
    total = total + sum_odd_indices(10);

    // count down from 5: 5+4+3+2+1 = 15
    total = total + count_down(5);

    // downto with step: 22
    total = total + downto_with_step();

    // step by three: 30
    total = total + step_by_three();

    // Expected: 20 + 25 + 15 + 22 + 30 = 112
    return total;
}
