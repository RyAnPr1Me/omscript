import std;
// own_on_frozen_error_test.om — verify E021 own-on-frozen
// This test is expected to FAIL at compile time with:
//   [E021] cannot assert unique ownership of 'x' — it is frozen
// It is used as a negative test (the compiler must reject this program).

fn main() -> int {
    var x = 42;
    freeze x;     // x is now permanently frozen
    own x;        // ERROR: E021 — freeze is irreversible; own cannot un-freeze
    return x;
}
