// sorting package - sorting algorithms for arrays

fn sort_bubble(arr) {
    sort(arr);
    return 0;
}

fn sort_selection(arr) {
    sort(arr);
    return 0;
}

fn sort_insertion(arr) {
    sort(arr);
    return 0;
}

fn sort_is_sorted(arr) {
    var n = len(arr);
    if (n <= 1) {
        return 1;
    }
    for (i in 1...n) {
        if (arr[i] < arr[i - 1]) {
            return 0;
        }
    }
    return 1;
}

fn sort_reverse(arr) {
    reverse(arr);
    return 0;
}
