import "parser.om";

fn main() {
    var src = "fn f(a, b) { return 0; }";
    
    var ts = tokenize(src);
    g_tok_types   = ts.types;
    g_tok_lexemes = ts.lexemes;
    g_tok_lines   = ts.lines;
    g_tok_cols    = ts.cols;
    g_tok_ivals   = ts.ivals;
    g_tok_fvals   = ts.fvals;
    g_tok_count   = ts.count;
    g_pos         = 4;  // position at comma
    g_had_error   = 0;
    g_nd_count    = 0;
    g_ch_count    = 0;
    g_ch          = [];
    g_nd_type     = [];
    g_nd_ival     = [];
    g_nd_fval     = [];
    g_nd_sval     = [];
    g_nd_sval2    = [];
    g_nd_c0       = [];
    g_nd_c1       = [];
    g_nd_c2       = [];
    g_nd_extra    = [];
    g_nd_nextra   = [];
    g_nd_line     = [];
    g_nd_col      = [];
    g_struct_names    = [];
    g_struct_name_cnt = 0;
    g_in_optmax       = 0;
    g_lambda_counter  = 0;
    g_error_msg       = "";

    println("pos=" + to_string(g_pos));
    println("peek_type=" + to_string(peek_type()));
    println("TOK_COMMA=" + to_string(TOK_COMMA));
    println("match_tok result: " + to_string(match_tok(TOK_COMMA)));
    println("pos after: " + to_string(g_pos));
    
    // Reset pos
    g_pos = 4;
    var cnt = 0;
    while (match_tok(TOK_COMMA)) {
        println("MATCHED COMMA! pos=" + to_string(g_pos));
        cnt = cnt + 1;
        break;
    }
    println("cnt=" + to_string(cnt));
    
    return 0;
}
