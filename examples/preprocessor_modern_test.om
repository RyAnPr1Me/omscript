import std;
// Comptime-based replacement for the original preprocessor_modern_test.om.
// Replaces bitwise #if conditions and predefined macros with comptime
// constants and runtime conditions.
// Expected exit code: 13

comptime { const ANSWER: int = 42; }
comptime { const MASK: int = 15; }    // 0x0F = 15
comptime { const SHFT: int = 3; }
// NOTE: VERSION, OS, ARCH are comptime-only strings; use inline checks for
// runtime string operations (see §5.9 of the Language Reference).

fn main() -> int {
    var total = 0;

    // Was: #if (ANSWER & MASK) == 10 → 42 & 15 = 10 → true
    if ((ANSWER & MASK) == 10) { total = total + 1; }

    // Was: #if (0xF0 | MASK) == 255 → 240 | 15 = 255 → true
    if ((0xF0 | MASK) == 255) { total = total + 1; }

    // Was: #if (0xFF ^ MASK) == 0xF0 → 255 ^ 15 = 240 = 0xF0 → true
    if ((0xFF ^ MASK) == 0xF0) { total = total + 1; }

    // Was: #if (~0) == -1 → true
    if ((~0) == -1) { total = total + 1; }

    // Was: #if (1 << SHFT) == 8 → 1 << 3 = 8 → true
    if ((1 << SHFT) == 8) { total = total + 1; }

    // Was: #if (32 >> 2) == 8 → 8 → true
    if ((32 >> 2) == 8) { total = total + 1; }

    // Was: #if (ANSWER > 10 ? 1 : 0) == 1 → true
    if ((ANSWER > 10 ? 1 : 0) == 1) { total = total + 1; }

    // Was: #if (ANSWER < 10 ? 99 : 7) == 7 → true
    if ((ANSWER < 10 ? 99 : 7) == 7) { total = total + 1; }

    // Was: #elifdef ANSWER — ANSWER is defined → branch taken
    total = total + 1;

    // Was: #elifndef NEVER_DEFINED — NEVER_DEFINED not defined → branch taken
    total = total + 1;

    // Was: non-empty __DATE__, __TIME__, __BASE_FILE__ checks.
    // VERSION, OS, ARCH are always non-empty compile-time strings.
    total = total + 1;   // VERSION is always non-empty
    total = total + 1;   // OS is always non-empty
    total = total + 1;   // ARCH is always non-empty

    return total;   // 13
}
