import std;

// ─────────────────────────────────────────────────────────────────────────────
// Round-95 feature tests
//   1. if-expression   — zero-cost ternary from if/else blocks
//   2. when on strings — string dispatch in when statement
//   3. Array comprehension — [expr for var in iterable [if cond]]
// ─────────────────────────────────────────────────────────────────────────────

// ── 1. if-expression ─────────────────────────────────────────────────────────
fn classify(n: int) -> string {
    return if n < 0 { "negative" } else { if n == 0 { "zero" } else { "positive" } };
}

fn abs_val(n: int) -> int {
    return if n < 0 { -n } else { n };
}

// ── 2. when on strings ───────────────────────────────────────────────────────
fn day_type(day: string) -> string {
    var result = "unknown";
    when day {
        "Saturday", "Sunday" => { result = "weekend"; }
        "Monday", "Tuesday", "Wednesday", "Thursday", "Friday" => { result = "weekday"; }
        _ => { result = "unknown"; }
    }
    return result;
}

fn fruit_color(fruit: string) -> string {
    var color = "unknown";
    when fruit {
        "apple"  => { color = "red"; }
        "banana" => { color = "yellow"; }
        "grape"  => { color = "purple"; }
        _ => { color = "other"; }
    }
    return color;
}

// ── 3. Array comprehension ───────────────────────────────────────────────────
fn sum_arr(a: int[]) -> int {
    var s = 0;
    for i in 0..len(a) { s = s + a[i]; }
    return s;
}

fn main() {
    // ── if-expression tests ──────────────────────────────────────────────────
    assert(classify(-5) == "negative");
    assert(classify(0)  == "zero");
    assert(classify(7)  == "positive");

    assert(abs_val(-10) == 10);
    assert(abs_val(10)  == 10);
    assert(abs_val(0)   == 0);

    // Inline in expressions
    var x = 8;
    var size_label = if x > 5 { "big" } else { "small" };
    assert(size_label == "big");

    // Without else branch (defaults to 0)
    var z = if x > 100 { 1 };
    assert(z == 0);

    // As function argument
    assert(str_len(if x > 0 { "positive" } else { "non-positive" }) == 8);

    // if-expression with optional parens
    assert((if (x == 8) { 1 } else { 0 }) == 1);

    // ── when-on-string tests ─────────────────────────────────────────────────
    assert(day_type("Saturday") == "weekend");
    assert(day_type("Sunday")   == "weekend");
    assert(day_type("Monday")   == "weekday");
    assert(day_type("Friday")   == "weekday");
    assert(day_type("Holiday")  == "unknown");

    assert(fruit_color("apple")  == "red");
    assert(fruit_color("banana") == "yellow");
    assert(fruit_color("grape")  == "purple");
    assert(fruit_color("mango")  == "other");

    // when without default (no-op when no arm matches)
    var hit = 0;
    var cmd = "stop";
    when cmd {
        "start" => { hit = 1; }
        "stop"  => { hit = 2; }
    }
    assert(hit == 2);

    // ── Array comprehension tests ─────────────────────────────────────────────
    // Range (exclusive)
    var squares = [x * x for x in 1..6];
    assert(len(squares) == 5);
    assert(squares[0] == 1);
    assert(squares[2] == 9);
    assert(squares[4] == 25);

    // Range (inclusive)
    var cubes = [x * x * x for x in 1..=5];
    assert(len(cubes) == 5);
    assert(cubes[4] == 125);

    // Map over existing array
    var arr = [1, 2, 3, 4, 5];
    var doubled = [x * 2 for x in arr];
    assert(len(doubled) == 5);
    assert(doubled[0] == 2);
    assert(doubled[4] == 10);

    // Filter + map
    var evens = [x for x in arr if x % 2 == 0];
    assert(len(evens) == 2);
    assert(evens[0] == 2);
    assert(evens[1] == 4);

    // Filter with computation
    var big_squares = [x * x for x in 1..11 if x * x > 25];
    assert(len(big_squares) == 5);   // 6,7,8,9,10 -> 36,49,64,81,100
    assert(big_squares[0] == 36);
    assert(big_squares[4] == 100);

    // Sum via comprehension + reduce
    var nums = [x for x in 1..6];
    assert(sum_arr(nums) == 15);

    println("All round95 tests passed");
    return 0;
}
