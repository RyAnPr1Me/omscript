// string_index_assign_test.om
//
// Regression test: s[i] = v previously applied array layout semantics to
// strings, writing an i64 value to offset (index+1)*8 bytes from the start
// of the string instead of a single byte at position index.  For short
// strings whose index happened to be small the write always landed in
// unrelated memory so the string appeared unchanged.
//
// After the fix, generateIndexAssign detects a string base expression and
// performs a byte-level store at position index (with correct strlen-based
// bounds check).  This only works on heap-allocated strings (str_concat,
// str_upper, str_lower, etc.) — literal strings reside in read-only memory.

fn main() {
    var total = 0;

    // Test 1: modify first byte
    var s1 = str_concat("hello", "");
    s1[0] = 72;   // 'H'
    total = total + (s1[0] == 72);    // +1
    // verify rest is unchanged: 'e' = 101
    total = total + (s1[1] == 101);   // +1

    // Test 2: modify last byte
    var s2 = str_concat("hello", "");
    s2[4] = 79;   // 'O'
    total = total + (s2[4] == 79);    // +1
    total = total + (s2[0] == 104);   // 'h' untouched  +1

    // Test 3: modify middle byte
    var s3 = str_lower("WORLD");
    s3[2] = 82;   // 'R'
    total = total + (s3[2] == 82);    // +1

    // Test 4: str[i] = str[j] (copy one char to another position)
    var s4 = str_concat("abcde", "");
    s4[0] = s4[4];   // s4[0] = 'e' (101)
    total = total + (s4[0] == 101);   // +1
    total = total + (s4[4] == 101);   // unchanged  +1

    // Test 5: loop-based modification (reverse in place simulation)
    var s5 = str_concat("abc", "");
    s5[0] = 99;   // 'c'
    s5[2] = 97;   // 'a'
    total = total + (s5[0] == 99);    // +1
    total = total + (s5[1] == 98);    // 'b' unchanged  +1
    total = total + (s5[2] == 97);    // +1

    // Test 6: variable index
    var s6 = str_concat("hello", "");
    var idx = 1;
    s6[idx] = 69;   // 'E'
    total = total + (s6[idx] == 69);  // +1

    // Expected: 11
    return total;
}
