// Test struct field attributes for optimization hints

struct Particle {
    hot immut int id,
    cold int last_used,
    align(64) int buffer,
    noalias int ptr,
    range(0,100) int score,
    move int inner
}

fn main() {
    var p = Particle { id: 1, last_used: 0, buffer: 42, ptr: 100, score: 50, inner: 200 };
    println(p.id);       // 1
    println(p.score);    // 50
    println(p.inner);    // 200
    return 0;
}
