import "parser.om";

fn main() {
    var src = "fn f(a, b) {}";
    
    // Manually set up the parser
    var ts = tokenize(src);
    g_tok_types = ts.types;
    g_tok_lexemes = ts.lexemes;
    g_tok_lines = ts.lines;
    g_tok_cols = ts.cols;
    g_tok_count = ts.count;
    g_pos = 0;
    g_had_error = 0;
    g_nd_count = 0;
    g_ch_count = 0;
    
    // Show tokens
    var i = 0;
    while (i < ts.count) {
        println(to_string(i) + ": type=" + to_string(ts.types[i]) + " [" + ts.lexemes[i] + "]");
        i = i + 1;
    }

    // Now try parsing step by step 
    println("--- Manual parse ---");
    // consume 'fn'
    println("pos=" + to_string(g_pos) + " type=" + to_string(peek_type()));
    var r1 = consume_tok(TOK_FN, "Expected fn");
    println("After fn: pos=" + to_string(g_pos));
    
    // consume identifier 'f'
    var r2 = consume_tok(TOK_IDENTIFIER, "Expected name");
    println("After name: pos=" + to_string(g_pos) + " name=" + tok_lex_at(r2));
    
    // consume '('
    var r3 = consume_tok(TOK_LPAREN, "Expected (");
    println("After (: pos=" + to_string(g_pos));
    
    // check for ')'
    println("check RPAREN: " + to_string(check_tok(TOK_RPAREN)));
    
    // consume first param 'a'
    var pp = consume_tok(TOK_IDENTIFIER, "Expected param");
    println("After param a: pos=" + to_string(g_pos) + " name=" + tok_lex_at(pp));
    
    // check for ':'
    println("check COLON: " + to_string(check_tok(TOK_COLON)));
    
    // check for ','
    println("peek type: " + to_string(peek_type()));
    println("TOK_COMMA: " + to_string(TOK_COMMA));
    println("check COMMA: " + to_string(check_tok(TOK_COMMA)));
    println("match COMMA: " + to_string(match_tok(TOK_COMMA)));
    println("After comma: pos=" + to_string(g_pos));
    
    return 0;
}
