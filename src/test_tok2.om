import "lexer.om";

fn main() {
    var src = "fn f(x) { return x + 1; }";
    var ts = tokenize(src);
    println("count=" + to_string(ts.count));
    println("types_len=" + to_string(len(ts.types)));
    println("lexemes_len=" + to_string(len(ts.lexemes)));
    var i = 0;
    while (i < ts.count) {
        println(to_string(i) + ": " + ts.lexemes[i]);
        i = i + 1;
    }
    return 0;
}
