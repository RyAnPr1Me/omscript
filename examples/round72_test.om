import std;

// Round-72 feature tests:
// 1. f"..." f-string syntax (alias for $"...")
// 2. `not in` operator: x not in arr → !array_contains(arr, x)
// 3. var (a, b) = expr — tuple destructuring from return value / literal
// 4. Named call arguments: foo(param: val, other: val2) — reordered to match decl

// Helper functions for named-argument tests
fn sub(a: int, b: int) -> int { return a - b; }
fn make_greeting(greeting: string, name: string) -> string {
    return greeting + ", " + name + "!";
}
fn rect(width: int, height: int) -> int { return width * height; }
fn clamp_val(lo: int, hi: int, x: int) -> int {
    if x < lo { return lo; }
    if x > hi { return hi; }
    return x;
}

fn get_pair() -> (int, int) { return (10, 20); }
fn get_triple() -> (int, int, int) { return (3, 7, 11); }
fn get_string_pair() -> (string, string) { return ("hello", "world"); }

fn main() -> int {
    var pass = 0;

    // ── 1. f-strings ────────────────────────────────────────────────────────
    var name = "OmScript";
    var ver = 72;
    var s1 = f"Round {ver} of {name}";
    if str_eq(s1, "Round 72 of OmScript") { pass = pass + 1; }  // +1

    var x = 6;
    var y = 7;
    var prod = f"{x} * {y} = {x * y}";
    if str_eq(prod, "6 * 7 = 42") { pass = pass + 1; }  // +2

    // f-string with expression
    var n = 5;
    var fs = f"fib({n}) = {n * (n + 1) / 2}";
    if str_eq(fs, "fib(5) = 15") { pass = pass + 1; }  // +3

    // Empty f-string
    var empty_fs = f"";
    if str_eq(empty_fs, "") { pass = pass + 1; }  // +4

    // f-string with escape sequences
    var escaped = f"tab:\there";
    if str_starts_with(escaped, "tab:") { pass = pass + 1; }  // +5

    // ── 2. `not in` operator ─────────────────────────────────────────────────
    var arr = [1, 2, 3, 4, 5];

    // 6 is not in arr → true
    if 6 not in arr { pass = pass + 1; }  // +6

    // 3 is in arr → `not in` should be false
    var was_false = true;
    if 3 not in arr { was_false = false; }
    if was_false { pass = pass + 1; }  // +7

    // 0 not in arr → true
    if 0 not in arr { pass = pass + 1; }  // +8

    // Combined: not in with string array
    var words = ["cat", "dog", "bird"];
    if "fish" not in words { pass = pass + 1; }  // +9

    var in_was_false2 = true;
    if "cat" not in words { in_was_false2 = false; }
    if in_was_false2 { pass = pass + 1; }  // +10

    // ── 3. Tuple destructuring ───────────────────────────────────────────────
    // Basic tuple destructure from function return
    var (a, b) = get_pair();
    if a == 10 && b == 20 { pass = pass + 1; }  // +11

    // Triple tuple
    var (p, q, r) = get_triple();
    if p == 3 && q == 7 && r == 11 { pass = pass + 1; }  // +12

    // Tuple from literal
    var (i, j) = (42, 99);
    if i == 42 && j == 99 { pass = pass + 1; }  // +13

    // Skip element with '_'
    var (first, _, third) = get_triple();
    if first == 3 && third == 11 { pass = pass + 1; }  // +14

    // String tuple destructure
    var (s_a, s_b) = get_string_pair();
    if str_eq(s_a, "hello") && str_eq(s_b, "world") { pass = pass + 1; }  // +15

    // Use destructured values in arithmetic
    var (m1, m2) = (6, 7);
    if m1 * m2 == 42 { pass = pass + 1; }  // +16

    // ── 4. Named call arguments ──────────────────────────────────────────────
    // sub(b:3, a:10) → reordered to sub(a=10, b=3) → 10 - 3 = 7
    var r1 = sub(b: 3, a: 10);
    if r1 == 7 { pass = pass + 1; }  // +17

    // All positional still works
    var r2 = sub(10, 3);
    if r2 == 7 { pass = pass + 1; }  // +18

    // rect(height:5, width:4) → 4 * 5 = 20
    var area = rect(height: 5, width: 4);
    if area == 20 { pass = pass + 1; }  // +19

    // Named args with string function
    var greet = make_greeting(name: "Alice", greeting: "Hello");
    if str_eq(greet, "Hello, Alice!") { pass = pass + 1; }  // +20

    // 3-argument named: clamp_val(x:15, lo:0, hi:10) → 10
    var clamped = clamp_val(x: 15, lo: 0, hi: 10);
    if clamped == 10 { pass = pass + 1; }  // +21

    // Named args: clamp_val(hi:100, lo:50, x:75) → 75
    var in_range = clamp_val(hi: 100, lo: 50, x: 75);
    if in_range == 75 { pass = pass + 1; }  // +22

    // Mixed: positional first, then named
    var r3 = sub(10, b: 3);
    if r3 == 7 { pass = pass + 1; }  // +23 — 10 positional, b:3 named

    println(pass);
    return pass;
}
