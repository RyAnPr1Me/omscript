// Test trigonometric and transcendental math built-in functions
fn main() {
    var total = 0;

    // Test sin: sin(0) = 0, so to_int(sin(0)) = 0
    total = total + to_int(sin(0.0));  // 0
    // total = 0

    // Test cos: cos(0) = 1
    total = total + to_int(cos(0.0));  // 1
    // total = 1

    // Test tan: tan(0) = 0
    total = total + to_int(tan(0.0));  // 0
    // total = 1

    // Test exp: exp(0) = 1
    total = total + to_int(exp(0.0));  // 1
    // total = 2

    // Test log: log(1) = 0
    total = total + to_int(log(1.0));  // 0
    // total = 2

    // Test log10: log10(100) = 2
    total = total + to_int(log10(100.0));  // 2
    // total = 4

    // Test cbrt: cbrt(27) = 3
    total = total + to_int(cbrt(27.0));  // 3
    // total = 7

    // Test cbrt: cbrt(8) = 2
    total = total + to_int(cbrt(8.0));  // 2
    // total = 9

    // Test hypot: hypot(3,4) = 5
    total = total + to_int(hypot(3.0, 4.0));  // 5
    // total = 14

    // Test hypot: hypot(5,12) = 13
    total = total + to_int(hypot(5.0, 12.0));  // 13
    // total = 27

    // Test asin: asin(0) = 0
    total = total + to_int(asin(0.0));  // 0
    // total = 27

    // Test acos: acos(1) = 0
    total = total + to_int(acos(1.0));  // 0
    // total = 27

    // Test atan: atan(0) = 0
    total = total + to_int(atan(0.0));  // 0
    // total = 27

    // Test atan2: atan2(0, 1) = 0
    total = total + to_int(atan2(0.0, 1.0));  // 0
    // total = 27

    // Test exp(1) ≈ 2.718 → to_int = 2
    total = total + to_int(exp(1.0));  // 2
    // total = 29

    // Test log10(1000) = 3
    total = total + to_int(log10(1000.0));  // 3
    // total = 32

    return total;
}
