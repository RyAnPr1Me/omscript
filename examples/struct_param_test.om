import std;

struct Vec2 { x: int, y: int }
struct Vec3 { x: int, y: int, z: int }
struct Rect { x: int, y: int, w: int, h: int }
struct Matrix2 { a: int, b: int, c: int, d: int }

fn dot2(a: Vec2, b: Vec2) -> int {
    return a.x * b.x + a.y * b.y;
}

fn len_sq(v: Vec3) -> int {
    return v.x * v.x + v.y * v.y + v.z * v.z;
}

fn rect_area(r: Rect) -> int {
    return r.w * r.h;
}

fn mat_det(m: Matrix2) -> int {
    return m.a * m.d - m.b * m.c;
}

fn translate(p: *Vec2, dx: int, dy: int) {
    p->x += dx;
    p->y += dy;
}

fn scale_vec(p: *Vec3, s: int) {
    p->x *= s;
    p->y *= s;
    p->z *= s;
}

fn make_unit() -> Vec2 {
    return Vec2 { x: 1, y: 0 };
}

fn main() -> int {
    var score: int = 0;

    // T1: struct pass-by-value
    var a: Vec2 = Vec2 { x: 3, y: 4 };
    var b: Vec2 = Vec2 { x: 1, y: 2 };
    score += (dot2(a, b) == 11);

    // T2: Vec3 len_sq
    var v: Vec3 = Vec3 { x: 2, y: 3, z: 6 };
    score += (len_sq(v) == 49);

    // T3: Rect area
    var r: Rect = Rect { x: 0, y: 0, w: 5, h: 7 };
    score += (rect_area(r) == 35);

    // T4: Matrix determinant
    var m: Matrix2 = Matrix2 { a: 2, b: 1, c: 3, d: 4 };
    score += (mat_det(m) == 5);

    // T5: struct pointer mutation via ->field +=
    var p: Vec2 = Vec2 { x: 1, y: 2 };
    translate(&p, 3, -1);
    score += (p.x == 4 && p.y == 1);

    // T6: Vec3 scale via *self
    var u: Vec3 = Vec3 { x: 1, y: 2, z: 3 };
    scale_vec(&u, 4);
    score += (u.x == 4 && u.y == 8 && u.z == 12);

    // T7: struct returned by value
    var unit: Vec2 = make_unit();
    score += (unit.x == 1 && unit.y == 0);

    // T8: struct nested field access
    var outer: Vec3 = Vec3 { x: 10, y: 20, z: 30 };
    var pp: *Vec3 = &outer;
    pp->x = pp->x * 2;
    score += (outer.x == 20);

    return score;
}
