import "parser.om";

fn main() {
    var src = "fn f(a, b) { return 0; }";
    
    var ts = tokenize(src);
    g_tok_types   = ts.types;
    g_tok_lexemes = ts.lexemes;
    g_tok_lines   = ts.lines;
    g_tok_cols    = ts.cols;
    g_tok_ivals   = ts.ivals;
    g_tok_fvals   = ts.fvals;
    g_tok_count   = ts.count;
    g_pos         = 0;
    g_had_error   = 0;
    g_nd_count    = 0;
    g_ch_count    = 0;
    g_ch          = [];
    g_nd_type     = [];
    g_nd_ival     = [];
    g_nd_fval     = [];
    g_nd_sval     = [];
    g_nd_sval2    = [];
    g_nd_c0       = [];
    g_nd_c1       = [];
    g_nd_c2       = [];
    g_nd_extra    = [];
    g_nd_nextra   = [];
    g_nd_line     = [];
    g_nd_col      = [];
    g_struct_names    = [];
    g_struct_name_cnt = 0;
    g_in_optmax       = 0;
    g_lambda_counter  = 0;
    g_error_msg       = "";

    println("tok_count=" + to_string(g_tok_count));
    
    // Now call parse_function directly
    var fn_node = parse_function(0, 0);
    if (fn_node == -1) {
        println("parse_function FAILED: " + g_error_msg);
    } else {
        println("parse_function OK, node=" + to_string(fn_node));
    }
    return 0;
}
