fn main() {
    print("Test 1: normal swap");
    var arr = [1, 2, 3];
    swap(arr, 0, 2);
    print(arr[0]);
    print(arr[1]);
    print(arr[2]);
    
    print("Test 2: swap same index");
    var arr2 = [1, 2, 3];
    swap(arr2, 1, 1);
    print(arr2[0]);
    print(arr2[1]);
    print(arr2[2]);
}
