global var g_pos2 = 0;
global var g_arr = [89, 3, 83, 84, 85, 93];

fn peek_type2() {
    return g_arr[g_pos2];
}

fn check_tok2(ty) {
    if (g_pos2 >= len(g_arr)) { return 0; }
    return peek_type2() == ty;
}

fn match_tok2(ty) {
    if (check_tok2(ty)) {
        g_pos2 = g_pos2 + 1;
        return 1;
    }
    return 0;
}

fn main() {
    g_pos2 = 0;
    // g_arr[0] = 89 which is the comma value
    println("Direct match_tok2(89): " + to_string(match_tok2(89)));
    println("pos after: " + to_string(g_pos2));
    
    g_pos2 = 0;
    var cnt = 0;
    while (match_tok2(89)) {
        println("MATCHED! pos=" + to_string(g_pos2));
        cnt = cnt + 1;
    }
    println("cnt=" + to_string(cnt));
    
    return 0;
}
