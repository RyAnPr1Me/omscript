// Test array slice syntax arr[start:end]
fn main() {
    var total = 0;
    var arr = [10, 20, 30, 40, 50];

    // Basic slice: arr[1:3] should give [20, 30]
    var s1 = arr[1:3];
    total = total + (len(s1) == 2);   // 1
    total = total + (s1[0] == 20);    // 1
    total = total + (s1[1] == 30);    // 1

    // Slice from beginning: arr[:2] gives [10, 20]
    var s2 = arr[:2];
    total = total + (len(s2) == 2);   // 1
    total = total + (s2[0] == 10);    // 1
    total = total + (s2[1] == 20);    // 1

    // Slice full range
    var s3 = arr[0:5];
    total = total + (len(s3) == 5);   // 1

    // Slice single element range
    var s4 = arr[2:3];
    total = total + (len(s4) == 1);   // 1
    total = total + (s4[0] == 30);    // 1

    // Empty slice
    var s5 = arr[2:2];
    total = total + (len(s5) == 0);   // 1

    // Slice is independent copy
    var s6 = arr[0:3];
    s6[0] = 999;
    total = total + (arr[0] == 10);   // 1 (original unchanged)

    // total = 11
    println(total);
    return total;
}
