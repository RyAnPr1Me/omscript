// throw_in_called_fn_test.om
//
// Tests that throw terminates normal control flow (code after throw never
// executes), catch(code) handlers intercept the correct code, and execution
// continues normally after the catch body.
// Expected return value: 147

fn main() {
    var result = 0;

    // Test 1: Conditional throw — code after throw never runs (+99)
    var b = 0;
    if (b == 0) {
        throw 99;
    }
    result = 1000;         // must NOT execute (b==0 always throws)
    catch(99) {
        result = result + 99;
    }

    // Test 2: No-throw path — normal arithmetic runs (+5)
    var x = 10;
    var y = 2;
    result = result + (x / y);
    catch(555) {
        result = result + 1000;  // unreachable
    }

    // Test 3: Conditional throw via variable (+3)
    var code = 3;
    if (code != 0) {
        throw 3;
    }
    result = result + 500;  // must NOT execute (code==3, always throws)
    catch(3) {
        result = result + 3;
    }

    // Test 4: Direct throw 10 (+10)
    throw 10;
    catch(10) {
        result = result + 10;
    }

    // Test 5: Direct throw 20 (+20)
    throw 20;
    catch(20) {
        result = result + 20;
    }

    // Test 6: Throw 7, catch it, then add 1 more (+7 +1)
    throw 7;
    catch(7) {
        result = result + 7;
    }
    result = result + 1;

    // Test 7: Final normal increment (+2)
    result = result + 2;

    // Expected: 99 + 5 + 3 + 10 + 20 + 7 + 1 + 2 = 147
    return result;
}
