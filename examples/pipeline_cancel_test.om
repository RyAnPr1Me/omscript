// pipeline_cancel_test.om — pipeline stage execution semantics
//
// Verifies that stages run in declaration order, __pipeline_i is correct,
// and one-shot vs. counted pipelines work as expected.
// Expected return value: 46

fn main() {
    var total = 0;

    // ── 1. Counted pipeline — 3 iterations, 3 stages ────────────────────────
    // load: x = __pipeline_i,  double: y = x*2,  accum: sum += y
    // Produces: 0+2+4 = 6
    var sum1 = 0;
    var x1 = 0;
    var y1 = 0;
    pipeline 3 {
        stage load   { x1 = __pipeline_i; }
        stage double { y1 = x1 * 2; }
        stage accum  { sum1 = sum1 + y1; }
    }
    total = total + sum1;   // 6

    // ── 2. One-shot pipeline — two independent stages ─────────────────────
    // a starts at 1, s1 adds 1 → 2.  b starts at 10, s2 adds 1 → 11.
    // total += 2 + 11 = 13  → 19
    var a2 = 1;
    var b2 = 10;
    pipeline {
        stage s1 { a2 = a2 + 1; }
        stage s2 { b2 = b2 + 1; }
    }
    total = total + a2 + b2;    // 2 + 11 = 13 → 19

    // ── 3. Counted pipeline — single stage, 5 iterations ────────────────────
    // Sums 5 increments of 1 → sum3 = 5
    var sum3 = 0;
    pipeline 5 {
        stage work { sum3 = sum3 + 1; }
    }
    total = total + sum3;       // +5 → 24

    // ── 4. Single-stage pipeline, 4 iterations — sum of i ───────────────────
    // 0+1+2+3 = 6
    var sum4 = 0;
    pipeline 4 {
        stage only { sum4 = sum4 + __pipeline_i; }
    }
    total = total + sum4;       // +6 → 30

    // ── 5. One-shot, 3-stage computation ────────────────────────────────────
    // v5 = 1 → +1 → 2 → *3 → 6 → +10 → 16
    var v5 = 1;
    pipeline {
        stage a { v5 = v5 + 1; }
        stage b { v5 = v5 * 3; }
        stage c { v5 = v5 + 10; }
    }
    total = total + v5;         // +16 → 46

    // Expected: 6 + 13 + 5 + 6 + 16 = 46
    return total;
}
