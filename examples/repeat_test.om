// Test the 'repeat' keyword (counted loop)
fn main() {
    var result = 0;

    // Basic repeat with literal count
    repeat 5 {
        result = result + 1;
    }
    // result = 5

    // Repeat with parenthesized count
    repeat (3) {
        result = result + 2;
    }
    // result = 5 + 6 = 11

    // Repeat with expression count
    var n = 4;
    repeat n {
        result = result + 3;
    }
    // result = 11 + 12 = 23

    // Repeat with computed expression
    repeat (2 + 1) {
        result = result + 10;
    }
    // result = 23 + 30 = 53

    // Nested repeat
    var count = 0;
    repeat 3 {
        repeat 4 {
            count = count + 1;
        }
    }
    result = result + count;
    // count = 3 * 4 = 12
    // result = 53 + 12 = 65

    return result;  // Expected: 65
}
