import "codegen.om";
fn main() {
    var src = "fn main() { return 42; }";
    var root = parse(src);
    if (root == -1) { println("parse failed"); return 1; }
    var ir = generate_llvm_ir(root);
    println("=== HEADER LENGTH: " + to_string(str_len(g_ir_header)));
    println("=== STR_DECLS LENGTH: " + to_string(str_len(g_str_decls)));
    println("=== IR LENGTH: " + to_string(str_len(g_ir)));
    println("=== RESULT LENGTH: " + to_string(str_len(ir)));
    println("=== FIRST 50 CHARS OF RESULT:");
    println(str_substr(ir, 0, 50));
    println("===");
    return 0;
}
