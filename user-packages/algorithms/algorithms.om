// algorithms package - common algorithms for arrays

fn algo_sum(arr) {
    return sum(arr);
}

fn algo_find_max(arr) {
    return array_max(arr);
}

fn algo_find_min(arr) {
    return array_min(arr);
}

fn algo_contains(arr, target) {
    return array_contains(arr, target);
}

fn algo_count(arr, target) {
    var length = len(arr);
    var c = 0;
    for (i in 0...length) {
        if (arr[i] == target) {
            c = c + 1;
        }
    }
    return c;
}
