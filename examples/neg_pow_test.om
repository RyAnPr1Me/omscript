// Test negative exponent edge cases for the power operator.
// 1 ** -5  → 1 (any power of 1 is 1)
// (-1) ** -3 → -1 (odd negative exponent of -1)
// (-1) ** -4 → 1 (even negative exponent of -1)
// 5 ** -2  → 0 (integer truncation of 0.04)
// 2 ** -1  → 0 (integer truncation of 0.5)
fn main() {
    var a = 1 ** -5;    // 1
    var b = (-1) ** -3; // -1
    var c = (-1) ** -4; // 1
    var d = 5 ** -2;    // 0
    var e = 2 ** -1;    // 0
    // Sum: 1 + (-1) + 1 + 0 + 0 = 1
    // Add offset for exit code readability
    return a + b + c + d + e + 10;
}
