// string_index_test.om
//
// Regression test: s[i] previously applied array layout semantics to strings,
// reading 8-byte chunks with a +1 offset (for the array length header that
// strings don't have), returning garbage pointer-sized integers.
//
// After the fix, s[i] reads the byte at position i and zero-extends to i64,
// matching the semantics of char_at(s, i).

fn sum_chars(s) {
    var total = 0;
    var i = 0;
    while (i < len(s)) {
        total = total + s[i];
        i = i + 1;
    }
    return total;
}

fn main() {
    var total = 0;

    // Test 1: individual character codes (ASCII)
    var s = "ABC";
    total = total + (s[0] == 65);   // 'A'  +1
    total = total + (s[1] == 66);   // 'B'  +1
    total = total + (s[2] == 67);   // 'C'  +1

    // Test 2: string literal indexing
    total = total + ("hello"[0] == 104);  // 'h'  +1
    total = total + ("hello"[4] == 111);  // 'o'  +1

    // Test 3: variable index
    var s2 = "hello";
    var idx = 1;
    total = total + (s2[idx] == 101);  // 'e'  +1

    // Test 4: matches char_at output
    total = total + (s2[0] == char_at(s2, 0));  // +1
    total = total + (s2[3] == char_at(s2, 3));  // +1

    // Test 5: sum over string via [] in while loop
    var got = sum_chars("hello");  // h+e+l+l+o = 104+101+108+108+111 = 532
    total = total + (got == 532);  // +1

    // Test 6: to_string result is indexable
    var ts = to_string(42);
    total = total + (ts[0] == 52);   // '4' = 52  +1
    total = total + (ts[1] == 50);   // '2' = 50  +1

    // Test 7: indexing the result of string concatenation
    var cat = "ab" + "cd";
    total = total + (cat[0] == 97);   // 'a'  +1
    total = total + (cat[3] == 100);  // 'd'  +1

    // Expected: 13
    return total;
}
