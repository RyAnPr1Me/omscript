import std;
// namespace_test.om — test user-defined namespace blocks (Round-53).
//
// Verifies:
//   - namespace Math { fn / struct } declarations
//   - qualified call: Math::add(3, 4)
//   - qualified struct literal: Math::Vec2 { x: 1, y: 2 }
//   - import Math; followed by bare calls: add(3, 4)
//   - bare struct literal after import: Vec2 { x: 5, y: 6 }
//
// Expected exit code: 0

namespace Math {
    fn add(a, b) {
        return a + b;
    }

    fn mul(a, b) {
        return a * b;
    }

    struct Vec2 { x, y }
}

import Math;

fn main() -> int {
    // Qualified function calls
    var r1 = Math::add(3, 4);
    if (r1 != 7) { return 1; }

    var r2 = Math::mul(3, 4);
    if (r2 != 12) { return 2; }

    // Qualified struct literal
    var v1 = Math::Vec2 { x: 10, y: 20 };
    if (v1.x != 10) { return 3; }
    if (v1.y != 20) { return 4; }

    // Bare calls after import Math;
    var r3 = add(3, 4);
    if (r3 != 7) { return 5; }

    var r4 = mul(3, 4);
    if (r4 != 12) { return 6; }

    // Bare struct literal after import Math;
    var v2 = Vec2 { x: 5, y: 6 };
    if (v2.x != 5) { return 7; }
    if (v2.y != 6) { return 8; }

    return 0;
}
