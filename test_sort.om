fn main() {
    print("Test 1: sort with negative numbers");
    var arr = [5, -3, 2, -1, 0];
    sort(arr);
    for (i in 0...5) {
        print(arr[i]);
    }
    
    print("Test 2: sort large negative");
    var arr2 = [100, -1000, 50];
    sort(arr2);
    print(arr2[0]);
    print(arr2[1]);
    print(arr2[2]);
}
