// Test elvis operator (?:)
fn main() {
    var total = 0;

    // Elvis with truthy value
    var a = 42;
    var r1 = a ?: 0;
    total = total + (r1 == 42);  // 1

    // Elvis with falsy value (0)
    var b = 0;
    var r2 = b ?: 99;
    total = total + (r2 == 99);  // 1

    // Elvis with literal
    var r3 = 7 ?: 0;
    total = total + (r3 == 7);   // 1

    // Elvis with zero literal
    var r4 = 0 ?: 55;
    total = total + (r4 == 55);  // 1

    // Nested elvis
    var c = 0;
    var d = 0;
    var e = 100;
    // c is 0, so check d; d is 0, so check e
    var r5 = c ?: (d ?: e);
    total = total + (r5 == 100); // 1

    // total = 5
    println(total);
    return total;
}
