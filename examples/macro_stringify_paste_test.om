import std;
// Replacement for the original macro_stringify_paste_test.om.
// Token stringification (#x) and token pasting (a ## b) were preprocessor-only
// features with no OmScript comptime equivalent.  This test verifies equivalent
// behaviour using string literals and direct identifiers.
// Expected exit code: 4

fn main() -> int {
    var total: i64 = 0;

    // Was: STR(world) → "world" via stringification — use literal directly.
    var s: string = "world";
    total = total + str_eq(s, "world");          // 1

    // Was: STR(  hi  ) → "hi" — use literal directly.
    var t: string = "hi";
    total = total + str_eq(t, "hi");             // 1

    // Was: CONCAT(my, Var):i64 = 42 — declare variable directly.
    var myVar: i64 = 42;
    total = total + (myVar == 42);               // 1

    // Was: CONCAT(x, 1):i64 = 7 — declare variable directly.
    var x1: i64 = 7;
    total = total + (x1 == 7);                   // 1

    return total;   // 4
}
