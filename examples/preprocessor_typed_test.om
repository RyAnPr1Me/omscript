import std;
// Typed-function replacement for the original preprocessor_typed_test.om.
// Typed macros are replaced by typed functions, which are inlined at O1+.
// Expected exit code: 6

// Functions replacing typed macros
fn ADD_RAW(x: int, y: int) -> int { return x + y; }
fn SQUARE(x: int) -> int { return x * x; }
fn SCALE(x: float, k: int) -> float { return x * to_float(k); }
fn GREET(s: string) -> string { return s; }
fn NEG(b: bool) -> bool { return !b; }

fn main() -> int {
    var total = 0;

    // Was: #define ADD_RAW(x, y) ((x) + (y))
    if (ADD_RAW(2, 3) == 5) { total = total + 1; }

    // Was: #define SQUARE(x: int) -> int  ((x) * (x))
    if (SQUARE(7) == 49) { total = total + 1; }

    // Was: #define SCALE(x: float, k: int) -> float  ((x) * (k))
    if (to_int(SCALE(1.5, 4)) == 6) { total = total + 1; }

    // Was: #define GREET(s: string) -> string  (s)
    if (len(GREET("hi")) == 2) { total = total + 1; }

    // Was: #define NEG(b: bool) -> bool  (!b)
    if (NEG(false) == true) { total = total + 1; }

    // Was: #define IDENTITY(x: any) -> any  (x) — use value directly
    var s: string = "ok";
    if (len(s) == 2) { total = total + 1; }

    return total;   // 6
}
