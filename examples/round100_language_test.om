import std;
// Round-100 language test: pipe-forward with extra args, array_partition, map_reduce

// ── Helpers for pipe-forward-with-args tests ─────────────────────────────────

fn add(a: int, b: int) -> int { return a + b; }
fn mul(a: int, b: int) -> int { return a * b; }
fn clamp(x: int, lo: int, hi: int) -> int {
    if x < lo { return lo; }
    if x > hi { return hi; }
    return x;
}

// ── Helpers for array_partition tests ────────────────────────────────────────

fn is_even(x: int) -> int { return (x % 2 == 0) ? 1 : 0; }
fn is_positive(x: int) -> int { return (x > 0) ? 1 : 0; }
fn gt_ten(x: int) -> int { return (x > 10) ? 1 : 0; }

// ── Helpers for map_reduce tests ─────────────────────────────────────────────

fn sum_values(acc: int, key: int, val: int) -> int { return acc + val; }
fn count_entries(acc: int, key: int, val: int) -> int { return acc + 1; }
fn max_value(acc: int, key: int, val: int) -> int {
    if val > acc { return val; }
    return acc;
}

// ── Pipe-forward with extra args ──────────────────────────────────────────────

fn test_pipe_extra_add() -> int {
    // 3 |> add(7)  →  add(3, 7) = 10
    var result = 3 |> add(7);
    return result == 10 ? 1 : 0;
}

fn test_pipe_extra_mul() -> int {
    // 6 |> mul(9)  →  mul(6, 9) = 54
    var result = 6 |> mul(9);
    return result == 54 ? 1 : 0;
}

fn test_pipe_extra_clamp() -> int {
    // 15 |> clamp(0, 10) → clamp(15, 0, 10) = 10
    var r1 = 15 |> clamp(0, 10);
    // -5 |> clamp(0, 10) → clamp(-5, 0, 10) = 0
    var r2 = -5 |> clamp(0, 10);
    // 7  |> clamp(0, 10) → clamp(7, 0, 10)  = 7
    var r3 = 7 |> clamp(0, 10);
    return (r1 == 10 && r2 == 0 && r3 == 7) ? 1 : 0;
}

fn test_pipe_chain_with_args() -> int {
    // Chain: 5 |> add(3) |> mul(2) → mul(add(5,3), 2) = mul(8,2) = 16
    var result = 5 |> add(3) |> mul(2);
    return result == 16 ? 1 : 0;
}

fn test_pipe_no_extra_args_still_works() -> int {
    // Existing form: x |> fn (no extra args) must still work
    var arr = [10, 20, 30];
    var n = arr |> len;
    return n == 3 ? 1 : 0;
}

// ── array_partition ────────────────────────────────────────────────────────────

fn test_partition_even_odd() -> int {
    var nums = [1, 2, 3, 4, 5, 6];
    var parts = array_partition(nums, is_even);
    // parts[0] = evens: [2, 4, 6]  → len 3
    // parts[1] = odds:  [1, 3, 5]  → len 3
    var evens = parts[0];
    var odds  = parts[1];
    if len(evens) != 3 { return 0; }
    if len(odds)  != 3 { return 0; }
    // Sum of evens should be 12
    var esum = array_sum(evens);
    if esum != 12 { return 0; }
    // Sum of odds should be 9
    var osum = array_sum(odds);
    if osum != 9 { return 0; }
    return 1;
}

fn test_partition_positive() -> int {
    var nums = [-3, -1, 0, 2, 5, -2, 8];
    var parts = array_partition(nums, is_positive);
    var pos = parts[0];
    var neg = parts[1];
    // Positive: [2, 5, 8]
    if len(pos) != 3 { return 0; }
    if array_sum(pos) != 15 { return 0; }
    // Non-positive: [-3, -1, 0, -2]
    if len(neg) != 4 { return 0; }
    return 1;
}

fn test_partition_all_pass() -> int {
    var nums = [11, 12, 13];
    var parts = array_partition(nums, gt_ten);
    if len(parts[0]) != 3 { return 0; }
    if len(parts[1]) != 0 { return 0; }
    return 1;
}

fn test_partition_none_pass() -> int {
    var nums = [1, 2, 3];
    var parts = array_partition(nums, gt_ten);
    if len(parts[0]) != 0 { return 0; }
    if len(parts[1]) != 3 { return 0; }
    return 1;
}

fn test_partition_empty() -> int {
    var nums: int[] = [];
    var parts = array_partition(nums, is_even);
    if len(parts[0]) != 0 { return 0; }
    if len(parts[1]) != 0 { return 0; }
    return 1;
}

// ── map_reduce ─────────────────────────────────────────────────────────────────

fn test_map_reduce_sum() -> int {
    var m = map_new();
    map_set(m, "a", 10);
    map_set(m, "b", 20);
    map_set(m, "c", 30);
    var total = map_reduce(m, 0, sum_values);
    return total == 60 ? 1 : 0;
}

fn test_map_reduce_count() -> int {
    var m = map_new();
    map_set(m, "x", 1);
    map_set(m, "y", 2);
    map_set(m, "z", 3);
    var cnt = map_reduce(m, 0, count_entries);
    return cnt == 3 ? 1 : 0;
}

fn test_map_reduce_max() -> int {
    var m = map_new();
    map_set(m, "p", 5);
    map_set(m, "q", 99);
    map_set(m, "r", 42);
    var mx = map_reduce(m, 0, max_value);
    return mx == 99 ? 1 : 0;
}

fn test_map_reduce_empty() -> int {
    var m = map_new();
    var result = map_reduce(m, 42, sum_values);
    return result == 42 ? 1 : 0;
}

fn main() -> int {
    var total = 0;

    // Pipe-forward with extra args (tests 1-5)
    total = total + test_pipe_extra_add();           // +1 → 1
    total = total + test_pipe_extra_mul();           // +1 → 2
    total = total + test_pipe_extra_clamp();         // +1 → 3
    total = total + test_pipe_chain_with_args();     // +1 → 4
    total = total + test_pipe_no_extra_args_still_works(); // +1 → 5

    // array_partition (tests 6-10)
    total = total + test_partition_even_odd();       // +1 → 6
    total = total + test_partition_positive();       // +1 → 7
    total = total + test_partition_all_pass();       // +1 → 8
    total = total + test_partition_none_pass();      // +1 → 9
    total = total + test_partition_empty();          // +1 → 10

    // map_reduce (tests 11-14)
    total = total + test_map_reduce_sum();           // +1 → 11
    total = total + test_map_reduce_count();         // +1 → 12
    total = total + test_map_reduce_max();           // +1 → 13
    total = total + test_map_reduce_empty();         // +1 → 14

    return total;
}
