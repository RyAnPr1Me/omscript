// Test: swap statement
// swap a, b; — swaps values of two variables

fn main() {
    var total = 0;

    // Basic swap
    var a = 10;
    var b = 20;
    swap a, b;
    // Now a=20, b=10
    total = total + a;   // 20
    total = total + b;   // 10

    // Swap back
    swap a, b;
    // Now a=10, b=20
    total = total + a;   // 10
    total = total + b;   // 20

    // Swap with zero
    var x = 42;
    var y = 0;
    swap x, y;
    // Now x=0, y=42
    total = total + y;   // 42

    // Multiple swaps
    var p = 1;
    var q = 2;
    var r = 3;
    swap p, q;   // p=2, q=1
    swap q, r;   // q=3, r=1
    total = total + p;   // 2
    total = total + q;   // 3
    total = total + r;   // 1

    // Expected: 20+10+10+20+42 + 2+3+1 = 108
    return total;
}
